# Copy to .env (gitignored). Minimal set required by Infisical's backend;
# see https://infisical.com/docs/self-hosting/configuration/envars for the
# full list of optional settings (SMTP, SSO, telemetry, etc).

# THESE ARE THE PROJECT'S OWN SAMPLE KEYS -- fine for a local POC, never reuse
# them beyond that. Generate real ones with:
#   openssl rand -hex 16   # ENCRYPTION_KEY
#   openssl rand -base64 32 # AUTH_SECRET
ENCRYPTION_KEY=f13dbc92aaaf86fa7cb0ed8ac3265f47
AUTH_SECRET=5lrMXKKWCVocS/uerPsl7V+TX/aaUaI7iDkgl3tSmLE=

# Infisical's own Postgres (separate from the coffee_soul db/ stack).
# Named INFISICAL_DB_* rather than POSTGRES_USER/POSTGRES_PASSWORD so these
# never collide with the coffee_soul secrets `infisical run` injects for the
# db/ service when you bring the whole poc/ stack up in one command.
INFISICAL_DB_USER=infisical
INFISICAL_DB_PASSWORD=infisical

REDIS_URL=redis://infisical-redis:6379

SITE_URL=http://localhost:8080
