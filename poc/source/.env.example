# Copy to .env (gitignored) for local dev, or export these as shell vars
# before `docker compose up` -- see poc/source/docker-compose.yml, which
# forwards them into the app container.
#
# For local dev without Infisical, any values work here. Once the
# infisical/ stack is running and configured, you can instead drop this
# file and launch with:
#   infisical run --project-config-dir=../db --env=dev --path=/ -- docker compose up
# which injects POSTGRES_USER/POSTGRES_PASSWORD at process start instead of
# reading them from this file.

POSTGRES_USER=coffee
POSTGRES_PASSWORD=coffee
