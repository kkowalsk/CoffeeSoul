# Copy to .env (gitignored) and fill in real values.
#
# For local dev without Infisical, any values work here.
# Once the infisical/ stack is running and you've created a project + secrets
# for these two keys, you can instead drop this file and launch with:
#   infisical run --env=dev --path=/coffee-soul -- docker compose up db
# which injects POSTGRES_USER/POSTGRES_PASSWORD at process start instead of
# reading them from this file.

POSTGRES_USER=<USER>
POSTGRES_PASSWORD=<PASSWORD>
